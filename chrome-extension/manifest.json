{
  "manifest_version": 3,
  "name": "Threej.in Games",
  "description": "Browse and launch games from threej.in directly from Chrome.",
  "version": "1.0.0",
  "action": {
    "default_title": "Threej.in Games",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": [
    "https://threej.in/*"
  ]
}
